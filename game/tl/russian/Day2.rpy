    "Немного жду, обдумывая ответ."

# game/Day2.rpy:3791
translate russian zooblunch2_4cd191e3:

    # a_nvl "I’m sorry Zooble, I’m so embarrassed"
    a_nvl "Прости, Зубл, мне так стыдно"

# game/Day2.rpy:3793
translate russian zooblunch2_b1b01cb2:

    # a_nvl "you can forget what I was saying"
    a_nvl "можешь забыть, что я говорила"

# game/Day2.rpy:3795
