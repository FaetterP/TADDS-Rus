translate russian zooblunch2_a9a991da:

    # z_nvl "I didn’t mean to call you weird"
    z_nvl "Я не хотела называть тебя странной"

# game/Day2.rpy:3777
translate russian zooblunch2_b5d58520:

    # z_nvl "I was just, you know, nervous"
    z_nvl "Просто, ну, нервничала"

# game/Day2.rpy:3779
translate russian zooblunch2_272c6d99:

    # z_nvl "I thought you knew the drinks I was serving you didn’t have alcohol in them"
    z_nvl "Думала, ты знаешь, что в напитках нет алкоголя"

# game/Day2.rpy:3781
translate russian zooblunch2_15b35bde:

    # z_nvl "but I’m sorry for not telling you"
    z_nvl "но прости, что не сказала"

# game/Day2.rpy:3783
translate russian zooblunch2_d6bd96eb:

    # z_nvl "I don’t think you’re weird"
    z_nvl "Я не считаю тебя странной"

# game/Day2.rpy:3785
translate russian zooblunch2_6fcb410d:

    # z_nvl "I’m sorry"
    z_nvl "Прости"

# game/Day2.rpy:3787
translate russian zooblunch2_ce6c677f:

    # "Oh thank god."
    "О слава богу."

# game/Day2.rpy:3789
translate russian zooblunch2_c7aceae2:

