translate russian jaxlunch_D2_94cf1714:

    # a "Uh, you know, the cool ones."
    a "Э-э, ну, классные."

# game/Day2.rpy:5564
translate russian jaxlunch_D2_64f59a84:

    # "She called my bluff, red alert, red alert!"
    "Она раскусила блеф — тревога, тревога!"

# game/Day2.rpy:5569
translate russian jaxlunch_D2_957d3e9b:

    # g "The"
    g "Клас-"

# game/Day2.rpy:5571
translate russian jaxlunch_D2_a43f7a11:

    # g "cool ones?"
    g "сные?"

# game/Day2.rpy:5573
translate russian jaxlunch_D2_93b68922:

    # "I stumble over my words for a second."
    "На секунду спотыкаюсь."

# game/Day2.rpy:5575
translate russian jaxlunch_D2_d33602f4:

    # a "H-how about you tell me about the ones you like?"
    a "А-а может, ты лучше расскажешь, какие нравятся тебе?"

# game/Day2.rpy:5580
translate russian jaxlunch_D2_598ee7f0:

    # g "Oh, don’t get me started! I like Yo Yo Hachoko, QuadGun, Uzumaki Ninja, Inner Yasha..."
    g "О, не заводи! Мне нравится Йо-Йо Хачоко, КвадГан, Узумаки Ниндзя, Внутренний Яша..."

# game/Day2.rpy:5588
translate russian jaxlunch_D2_3502b7e6:

    # "I keep nodding and smiling as Jax sneaks up behind Gangle, a shop-vac in hand and a dark grin on his face."
    "Продолжаю кивать и улыбаться, пока Джекс крадётся сзади к Гэнгл — в руке промышленный пылесос, на лице зловещая ухмылка."

# game/Day2.rpy:5590
translate russian jaxlunch_D2_178ec7e6:

    # "He’s just about to press the power button when-"
    "Он уже почти нажимает кнопку включения, как-"

