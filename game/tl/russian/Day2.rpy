# game/Day2.rpy:5417
translate russian jax_route_1759c752:

    # k "Who’s eating Jax?"
    k "Кто ест Джекса?"

# game/Day2.rpy:5419
translate russian jax_route_e526dd0f:

    # "He seems genuinely panicked by the prospect."
    "Он, кажется, по-настоящему напуган этой перспективой."

# game/Day2.rpy:5424
translate russian jax_route_17f6a37f:

