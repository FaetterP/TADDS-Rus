    # g "That’s much better!"
    g "Вот это другое дело!"

# game/Day2.rpy:2917
translate russian ganwait_fd64ce3c:

    # "Zooble nods."
    "Зубл кивает."

# game/Day2.rpy:2919
translate russian ganwait_7bc74247:

