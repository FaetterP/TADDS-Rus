translate russian ragcheckpoint_ddb82dea:

    # "Zooble sighs."
    "Зубл вздыхает."

# game/Day5.rpy:3508
translate russian ragcheckpoint_12c320ca:

    # "Uh oh."
    "Ой-ой."

# game/Day5.rpy:3513
translate russian ragcheckpoint_82aefdd3:

    # z "She, uh, she told me to talk to you if you showed up."
    z "Она, э-э, она попросила меня поговорить с тобой, если ты появишься."

# game/Day5.rpy:3518
translate russian ragcheckpoint_5a651533:

    # z "She just wants you to, well"
    z "Она просто хочет, чтобы ты, ну"

