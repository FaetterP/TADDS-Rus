translate russian ragcheckpoint_11ea9683:

    # z "Not go looking for her?"
    z "Не искать её?"

# game/Day5.rpy:3542
translate russian ragcheckpoint_943558b6:

    # "All of the breath leaves my lungs."
    "Воздух вылетает из лёгких."

# game/Day5.rpy:3544
translate russian ragcheckpoint_d32c77f4:

    # "I didn’t realize."
    "Не понимал(-а)."

# game/Day5.rpy:3546
translate russian ragcheckpoint_eed60daa:

    # "I didn’t know."
    "Не знал(-а)."

# game/Day5.rpy:3548
translate russian ragcheckpoint_e9448d92:

    # "Ugh."
    "Ugh."

