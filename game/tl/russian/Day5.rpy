translate russian ragcheckpoint_502f5baf:

    # "Zooble leaves me to my thoughts, going to rejoin Gangle as I try to process what they just told me."
    "Зубл оставляет меня наедине с мыслями и уходит к Гэнгл, пока пытаюсь осмыслить услышанное."

# game/Day5.rpy:3554
translate russian ragcheckpoint_0c4b192d:

    # "Ragatha..."
    "Рагата..."

# game/Day5.rpy:3556
translate russian ragcheckpoint_4f989db0:

    # "Did"
    "Неужели"

# game/Day5.rpy:3558
translate russian ragcheckpoint_9772f296:

    # "Did I really ruin everything?"
    "Неужели я и правда всё испортил(-а)?"

# game/Day5.rpy:3560
translate russian ragcheckpoint_3f739ce1:

    # "I sigh."
    "Вздыхаю."

# game/Day5.rpy:3562
translate russian ragcheckpoint_e3328664:

    # "Well, if it’s what she really wants."
    "Ну, если она этого хочет."

# game/Day5.rpy:3566
translate russian ragcheckpoint_b089f22e:

    # "I try to find something to occupy myself until the culture fair ends."
    "Пытаюсь найти себе занятие до конца культурного фестиваля."

# game/Day5.rpy:3568
translate russian ragcheckpoint_15b843ae:

    # "What a waste of a week."
    "Потерянная неделя."

# game/Day5.rpy:3570
translate russian ragcheckpoint_abb2e3b0:

    # "I don’t even know what I did."
    "Даже не понимаю, что сделал(-а) не так."

# game/Day5.rpy:3572
translate russian ragcheckpoint_37344b95:

    # "Every once in a while I catch a pitying glance from Zooble or Gangle."
