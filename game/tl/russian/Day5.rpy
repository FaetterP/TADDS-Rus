# game/Day5.rpy:3469
translate russian ragcheckpoint_fb4de207:

    # "As I scan the crowd for Ragatha, I eventually see her."
    "Пока осматриваю толпу в поисках Рагаты, наконец замечаю её."

# game/Day5.rpy:3471
translate russian ragcheckpoint_e19e91d7:

    # a "Ragatha!"
    a "Рагата!"

# game/Day5.rpy:3476
