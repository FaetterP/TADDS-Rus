    # "Zooble takes a deep breath."
    "Зубл делает глубокий вдох."

# game/Day5.rpy:3528
translate russian ragcheckpoint_f8d4cca7:

    # z "She just wants some space."
    z "Она просто хочет немного пространства."

# game/Day5.rpy:3530
translate russian ragcheckpoint_bd86321b:

    # z "She said that things got really awkward last night, and she asked me to talk to you."
    z "Она сказала, что прошлой ночью всё стало очень неловким, и попросила меня поговорить с тобой."

# game/Day5.rpy:3535
translate russian ragcheckpoint_2230f586:

    # z "Can you just do us all a favor and"
    z "Можешь сделать нам всем одолжение и"

