    g "И я очень рада, что ты пришёл(-ла) в наш класс."

# game/Day5.rpy:2235
translate russian gangle_D5_b42cffc0_2:

    # a "Me too, Gangle."
    a "Я тоже, Гэнгл."

# game/Day5.rpy:2237
