    # "What’s going on?"
    "Что происходит?"

# game/Day5.rpy:3488
translate russian ragcheckpoint_c77de69f:

    # "I feel a hand on my shoulder."
    "Чувствую руку на плече."

# game/Day5.rpy:3493
translate russian ragcheckpoint_bebd6c68:

    # "Zooble?"
    "Зубл?"

# game/Day5.rpy:3497
translate russian ragcheckpoint_8e6790e6:

    # z "Hey, [avatar]."
    z "Эй, [avatar]."

# game/Day5.rpy:3499
translate russian ragcheckpoint_ba7f1cc0:

    # a "Hey Zooble, I’m trying to talk to Ragatha, I"
    a "Эй, Зубл, я пытаюсь поговорить с Рагатой, я"

# game/Day5.rpy:3504
translate russian ragcheckpoint_a77b3519:

    # z "Yeah, about that [avatar],"
    z "Да, вот как раз об этом, [avatar],"

